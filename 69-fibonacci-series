public List<Integer> fibonacciSeries(Integer n) {
    List<Integer> numList = new List<Integer>();
    for(Integer i =1;i<=n;i++)
    {
        if(i<=2)
        {
            numList.add(1);
        }
        else
        {
            Integer fibo = numList[i]+numList[i-1];
            numList.add(fibo);
        }
    }
    return numList;
}