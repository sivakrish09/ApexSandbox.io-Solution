public Integer maxConsecutiveOnes(Integer[] numbers) {
    Integer tempcount =0;
    Integer permCount =0;

    for(Integer i=0;i<=numbers.size();i++)
    {
        if(numbers[i]==1)
        {
            tempcount = tempcount +1;
            permCount = (permCount < tempcount) ? tempcount : permCount;
        }
        else 
        {
            tempcount = 0;
        }
    }
    return permCount;
}